            "type": "json",
            "required": false
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        },
        "link_demo": {
            "type": "string",
            "required": false
        },
        "link_github": {
            "type": "string",
            "required": false
        }
    }
